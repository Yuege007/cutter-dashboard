﻿## API 配置（示例）
VITE_API_BASE_URL=https://apict.jijiayun.com

## 应用配置
VITE_APP_TITLE=数字看板系统
VITE_APP_VERSION=1.0.0

## 开发配置
VITE_DEV_PORT=3000

## 缓存配置
# 是否启用重数据写入 IndexedDB（默认关闭）。
# 关闭时，重数据仅走内存缓存，避免占用 localStorage。
VITE_CACHE_HEAVY_USE_IDB=false
VITE_CACHE_CLEAN_ON_REFRESH=false

# 将真实配置写入 .env（已被 .gitignore 忽略），此文件仅作为参考
